# Frontend environment variables (Vite injects VITE_* vars at build time)

# App environment label
VITE_APP_ENVIRONMENT="development"

# App mode: "prototype" (default) mounts persona + state dev bars for internal
# iteration. "build" strips them — use this for phase-build demos and
# production deployments where those dev controls shouldn't be visible.
VITE_APP_MODE="prototype"

# Theme panel visibility: "true" (default) mounts the floating theme FAB +
# panel in every deployment. Set to "false" to strip the theme controls
# entirely — use this for customer-facing deployments where retheming
# shouldn't be exposed to end users.
VITE_ENABLE_THEME_PANEL="true"

# API base URL
# Dev: leave empty — Vite proxy handles /api/* -> localhost:8000
# Prod: set to backend URL, e.g. https://api.example.com/api/v1
VITE_API_URL=

# When "true", Growth Journey card calls the speculative
# /core/employees/{id}/growth-journey endpoint. When unset/"false",
# the card renders a hardcoded mock fixture (default).
VITE_GROWTH_JOURNEY_LIVE=false