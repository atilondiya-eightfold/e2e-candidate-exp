# Frontend production build-time env.
# These values are baked into the bundle at build time. No secrets here.
# Real EF auth happens server-side in the BFF catch-all proxy.
VITE_APP_ENVIRONMENT="production"
VITE_APP_MODE="build"
VITE_ENABLE_THEME_PANEL="false"
VITE_API_URL=
VITE_EF_DOMAIN=eightfold
VITE_EF_API_TOKEN=placeholder-overridden-by-bff
