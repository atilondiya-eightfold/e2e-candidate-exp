# Copy this to .env and fill in real values. Never commit .env.

# --- Eightfold API (BFF -> upstream) ---
EF_API_BASE_URL=https://api.eightfold.ai
EF_OAUTH_TOKEN_URL=https://api.eightfold.ai/oauth/token
EF_OAUTH_CLIENT_ID=
EF_OAUTH_CLIENT_SECRET=

# --- Session cookie (parent -> BFF) ---
# Must match the secret used by the parent app (PCS) to sign _eftf_session
EF_SESSION_SECRET=

# --- CORS / hosts ---
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_HOST=http://localhost:5173

# --- Server ---
PORT=8000
